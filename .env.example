SECRET_KEY=your-secret
JWT_SECRET_KEY=another-secret
MYSQL_USER=learning
MYSQL_PASSWORD=learning
MYSQL_HOST=root
MYSQL_PORT=3306
MYSQL_DATABASE=learning
DATABASE_URL=mysql+pymysql://learning:learning@db:3306/learning?charset=utf8mb4
CORS_ORIGINS=http://localhost:3000
UPLOAD_PATH=/uploads
CACHE_TYPE=SimpleCache

# Email (credentials / notifications)
# You can set either SMTP_* or MAIL_* variables. MAIL_* are shown below.
# For port 465, typically MAIL_USE_SSL=True and MAIL_USE_TLS=False.
MAIL_SERVER=mail.example.com
MAIL_PORT=465
MAIL_USERNAME=notifications@example.com
MAIL_PASSWORD=change-me
MAIL_USE_TLS=False
MAIL_USE_SSL=True
MAIL_DEFAULT_SENDER=notifications@example.com

# Optional: public login page URL used in credential emails
APP_PUBLIC_LOGIN_URL=https://your-frontend-domain/login
